# ── Demo Mode ─────────────────────────────────────────────────────────────────
# Set to "false" to use real API integrations (requires all credentials below)
DEMO_MODE=true

# ── Digest Behavior ───────────────────────────────────────────────────────────
DIGEST_INTERVAL_MINS=30      # How often the digest refreshes (minutes)
URGENT_REPLY_HOURS=2         # Email unanswered > N hours → urgent
UPCOMING_MEETING_MINS=120    # Meetings within N minutes → show in digest

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5050

# ── Gmail (Google OAuth2) ─────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (Desktop app)
# 3. Download the JSON and place it at the path below
GMAIL_CREDENTIALS_FILE=credentials/gmail_credentials.json
GMAIL_TOKEN_FILE=credentials/gmail_token.json

# ── Google Calendar (reuses same OAuth app as Gmail) ──────────────────────────
GCAL_CREDENTIALS_FILE=credentials/gcal_credentials.json
GCAL_TOKEN_FILE=credentials/gcal_token.json

# ── Slack ─────────────────────────────────────────────────────────────────────
# 1. Go to https://api.slack.com/apps → Create New App → From Scratch
# 2. OAuth & Permissions → Add scopes: channels:history, im:history, stars:read, users:info
# 3. Install to workspace → copy Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-token-here

# ── Linear ────────────────────────────────────────────────────────────────────
# 1. Go to https://linear.app/settings/api → Personal API keys → Create key
LINEAR_API_KEY=lin_api_your-key-here
LINEAR_TEAM_ID=                         # Optional: filter to a specific team
